# Streamlit Cloud 배포용 시크릿 템플릿
# ─────────────────────────────────────────────────────────────
# 이 파일은 "예시"다. 실제 키를 넣지 말 것.
# 배포: Streamlit Community Cloud → 앱 → Settings → Secrets 에
#       아래 두 줄을 실제 키로 채워 붙여넣는다.
#       (최상위 키는 os.getenv()로도 읽히므로 코드 수정 불필요)
# 로컬: 이 파일을 secrets.toml 로 복사해 채우거나, 기존처럼 .env 사용.
#
# live 모드로 배포하려면 AGENT_MODE 도 함께 넣는다(기본값은 mock).

OPENAI_API_KEY = "sk-proj-..."
ANTHROPIC_API_KEY = "sk-ant-api03-..."
AGENT_MODE = "live"
